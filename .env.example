# able-asr — environment configuration template
# ---------------------------------------------------------------------------
# Copy this file to ``.env.local`` and fill in real values. ``.env.local`` is
# gitignored. The start scripts load ``.env`` first then ``.env.local`` (so
# ``.env.local`` overrides shared defaults).
#
# Every env var declared here is read in voice/config.py — adding a new one
# means adding to config.py too.

# ╔══════════════════════════════════════════════════════════════════╗
# ║ Secrets                                                          ║
# ╚══════════════════════════════════════════════════════════════════╝

# DashScope (Alibaba) — used by:
#   - ASR_PROVIDER=dashscope (paraformer-realtime-v2 streaming)
#   - LLM_PROVIDER=dashscope (qwen-* chat)
#   - TTS_PROVIDER=dashscope (qwen3-tts-*-flash)
#   - POLISH_PROVIDER=dashscope (the polish agent backend)
# One key serves all four — same vendor account.
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# Ablework backend JWT — used by LLM_PROVIDER=ablework.
ABLEWORK_TOKEN=eyJ...your-jwt-here

# ╔══════════════════════════════════════════════════════════════════╗
# ║ Provider selection (the 9 combos = 3 stages × multi-backends)    ║
# ╚══════════════════════════════════════════════════════════════════╝

# ASR — speech recognition
# Options: mlx (local Qwen3-ASR) | dashscope (cloud paraformer-realtime-v2)
ASR_PROVIDER=mlx

# LLM — chat generation
# Options: mlx | ollama | dashscope | ablework
LLM_PROVIDER=ablework

# TTS — speech synthesis
# Options: mlx (local CustomVoice, 9 voices) | dashscope (~50 voices incl. Maia)
TTS_PROVIDER=mlx

# Polish agent (LangGraph) — turns rambling ASR into clean written text
# Options: mlx | dashscope | off
POLISH_PROVIDER=mlx
POLISH_ENABLED=1                    # 0 disables polish entirely
POLISH_USE_FOR_CHAT=1               # 0 = polished text shown but chat still gets raw

# ╔══════════════════════════════════════════════════════════════════╗
# ║ MLX local model overrides (only consumed for matching provider)  ║
# ╚══════════════════════════════════════════════════════════════════╝

# MLX_QWEN_MODEL=Qwen/Qwen3-ASR-1.7B                     # try 0.6B for ~3GB less RAM
# MLX_LLM_MODEL=mlx-community/Qwen3-4B-Instruct-2507-4bit
# MLX_LLM_MAX_TOKENS=512
# MLX_TTS_MODEL=mlx-community/Qwen3-TTS-12Hz-1.7B-CustomVoice-bf16
# MLX_TTS_VOICE=serena                                    # 9 builtin: serena, vivian, ono_anna, sohee, ryan, aiden, dylan, eric, uncle_fu
# MLX_TTS_LANG=chinese
# MLX_TTS_TEMPERATURE=0.5
# MLX_TTS_SEED=42
# MLX_TTS_INSTRUCT=请用平稳、冷静、像新闻播报员的语气朗读,语速适中,不要加入任何情绪起伏。
# MLX_TTS_SR=24000

# TTS chunk post-processing
# MLX_TTS_TARGET_RMS=0.12
# MLX_TTS_MAX_GAIN=4.0
# MLX_TTS_TRIM_DBFS=-40
# MLX_TTS_KEEP_HEAD_MS=20
# MLX_TTS_KEEP_TAIL_MS=30

# ASR streaming chunk size — 1.5s = clean partials; <1s fragments words
# ASR_STREAM_CHUNK_SEC=1.5

# ╔══════════════════════════════════════════════════════════════════╗
# ║ Cloud backend overrides                                          ║
# ╚══════════════════════════════════════════════════════════════════╝

# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen3.7-max                            # chat LLM
# DASHSCOPE_THINKING=0                                    # 1 keeps reasoning_content (~slow)
# DASHSCOPE_ASR_MODEL=paraformer-realtime-v2
# DASHSCOPE_ASR_LANG=zh
# DASHSCOPE_ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference/
# DASHSCOPE_TTS_MODEL=qwen3-tts-instruct-flash           # or qwen3-tts-flash (cheaper, no `instructions`)
# DASHSCOPE_TTS_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# DASHSCOPE_TTS_LANG=Chinese
# POLISH_DASHSCOPE_MODEL=qwen-flash                       # cheaper model for polish

# Ollama (local) — only when LLM_PROVIDER=ollama
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3.5:35b
# OLLAMA_THINK=0

# Ablework backend
# ABLEWORK_URL=https://ab.itseek.cc/api/chat
# ABLEWORK_VERIFY_SSL=0                                   # 1 enables cert verify (default off for MITM proxy envs)

# ╔══════════════════════════════════════════════════════════════════╗
# ║ Polish agent tuning                                              ║
# ╚══════════════════════════════════════════════════════════════════╝

# POLISH_MAX_TOKENS=256
# POLISH_TEMPERATURE=0.2
# POLISH_MAX_ATTEMPTS=2                                   # initial + 1 retry

# ╔══════════════════════════════════════════════════════════════════╗
# ║ Sentence splitter (TTS streaming cadence)                        ║
# ╚══════════════════════════════════════════════════════════════════╝

# CHAT_SENT_MIN_CHARS=6
# CHAT_SENT_SOFT_CAP=40
# CHAT_FIRST_MIN_CHARS=6
# CHAT_FIRST_SOFT_CAP=24

# ╔══════════════════════════════════════════════════════════════════╗
# ║ System prompt                                                    ║
# ╚══════════════════════════════════════════════════════════════════╝

# Inline (single line, escape newlines as \\n if needed):
# SYSTEM_PROMPT=你是一个语音助手。...

# Or point at a file (preferred — default has TTS-friendly format rules
# like "不要输出股票代码 / 英文缩写 / url",see voice/config.py for the
# baseline). Tune your domain vocab here without editing code:
# SYSTEM_PROMPT_FILE=prompts/system.md

# ╔══════════════════════════════════════════════════════════════════╗
# ║ Storage / lifecycle                                              ║
# ╚══════════════════════════════════════════════════════════════════╝

# KEEP_AUDIO=0                  # 1 = archive every finalized recording to recordings/
# WARMUP=1                      # 0 skips startup model preload (faster boot, slower first call)

# ╔══════════════════════════════════════════════════════════════════╗
# ║ Mic device override (TUI client only)                            ║
# ╚══════════════════════════════════════════════════════════════════╝

# VOICE_INPUT_DEVICE=6          # PortAudio device index (run mic-check.py to list)
# VOICE_INPUT_NAME=MacBook      # substring match — survives BT reconnect renumbering
